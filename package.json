{
  "name": "openclaw-habitat",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "@types/node": "^22.13.10"
  },
  "scripts": {
    "dev:desktop": "pnpm --filter @openclaw-habitat/macos-shell dev:desktop",
    "dev": "pnpm --filter @openclaw-habitat/macos-shell dev",
    "build": "pnpm -r build",
    "dist:mac": "pnpm --filter @openclaw-habitat/macos-shell dist:mac",
    "dist:win": "pnpm --filter @openclaw-habitat/macos-shell dist:win",
    "start:desktop": "pnpm --filter @openclaw-habitat/macos-shell start:desktop",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  }
}
